---
import Layout from '../../layouts/Layout.astro';
import { readdir, readFile } from 'fs/promises';
import { join } from 'path';

export async function getStaticPaths() {
  const dir = join(process.cwd(), 'src/content/rankings');
  const files = await readdir(dir).catch(() => []);
  return Promise.all(
    files
      .filter(f => f.endsWith('.json'))
      .map(async f => {
        const data = JSON.parse(await readFile(join(dir, f), 'utf-8'));
        return { params: { slug: data.slug }, props: { ranking: data } };
      })
  );
}

const { ranking } = Astro.props;
---

<Layout title={ranking.title} description={ranking.description}>
  <div class="mb-6">
    <a href="/" class="text-sm text-indigo-500 hover:underline">← Back to all rankings</a>
  </div>

  <div class="mb-8">
    <span class="text-xs font-semibold text-indigo-500 uppercase tracking-wide">{ranking.category}</span>
    <h1 class="text-3xl font-bold mt-1 mb-2">{ranking.title}</h1>
    <p class="text-gray-500">{ranking.description}</p>
    <p class="text-xs text-gray-400 mt-2">Last updated: {ranking.updatedAt}</p>
  </div>

  <div class="space-y-4">
    {ranking.items.map((item: any) => (
      <div class="bg-white rounded-xl border border-gray-200 p-6 hover:shadow-sm transition-all">
        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 w-12 h-12 bg-indigo-50 rounded-xl flex items-center justify-center">
            <span class="text-xl font-bold text-indigo-600">#{item.rank}</span>
          </div>
          <div class="flex-1">
            <div class="flex items-center justify-between mb-1">
              <h2 class="text-xl font-bold">{item.name}</h2>
              <span class="text-sm font-semibold text-yellow-500">⭐ {item.score}/10</span>
            </div>
            <p class="text-gray-500 text-sm mb-3">{item.tagline}</p>
            <div class="grid grid-cols-2 gap-4 text-sm mb-3">
              <div>
                <p class="font-semibold text-green-600 mb-1">Pros</p>
                <ul class="space-y-1">
                  {item.pros.map((p: string) => <li class="text-gray-600">✓ {p}</li>)}
                </ul>
              </div>
              <div>
                <p class="font-semibold text-red-500 mb-1">Cons</p>
                <ul class="space-y-1">
                  {item.cons.map((c: string) => <li class="text-gray-600">✗ {c}</li>)}
                </ul>
              </div>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-xs text-gray-400">{item.pricing}</span>
              <a href={item.url} target="_blank" rel="noopener"
                 class="text-sm text-indigo-600 hover:underline font-medium">
                Visit site →
              </a>
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>
</Layout>
