---
import Layout from '../../layouts/Layout.astro';
import { readdir, readFile } from 'fs/promises';
import { join } from 'path';
import { supportedLangs, useTranslations, getI18n, type Lang } from '../../i18n/translations';

export function getStaticPaths() {
  return supportedLangs.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);

const rankingsDir = join(process.cwd(), 'src/content/rankings');
const files = await readdir(rankingsDir).catch(() => []);
const rankings = (await Promise.all(
  files.filter(f => f.endsWith('.json'))
    .map(async f => JSON.parse(await readFile(join(rankingsDir, f), 'utf-8')))
)).sort((a, b) => {
  const aDate = a.history?.at(-1)?.date ?? '';
  const bDate = b.history?.at(-1)?.date ?? '';
  return bDate.localeCompare(aDate);
});

// Today's biggest rank movers
type Mover = { name: string; slug: string; rankingTitle: string; prev: number; curr: number; delta: number };
const movers: Mover[] = [];
for (const r of rankings) {
  const history = r.history ?? [];
  const latest = history[history.length - 1];
  const previous = history[history.length - 2];
  if (!latest || !previous) continue;
  const competitorMap = Object.fromEntries(r.competitors.map((c: any) => [c.id, c]));
  const rankingTitle = getI18n(r.i18n, lang)?.title ?? r.slug;
  for (const curr of latest.rankings) {
    const prev = previous.rankings.find((p: any) => p.id === curr.id);
    if (!prev) continue;
    const delta = prev.rank - curr.rank;
    if (Math.abs(delta) >= 1) {
      movers.push({ name: competitorMap[curr.id]?.name ?? curr.id, slug: r.slug, rankingTitle, prev: prev.rank, curr: curr.rank, delta });
    }
  }
}
movers.sort((a, b) => Math.abs(b.delta) - Math.abs(a.delta));
const topMovers = movers.slice(0, 6);

const categories = [...new Set(rankings.map((r: any) => r.category))];
---

<Layout title="TopRankLand — Daily Consumer Rankings" lang={lang} currentPath="/">
  <!-- Hero -->
  <section class="text-center py-12 mb-4">
    <h1 class="text-4xl font-bold text-indigo-600 mb-4">TopRankLand</h1>
    <p class="text-xl text-gray-500 max-w-2xl mx-auto">{t('hero_subtitle')}</p>
  </section>

  <!-- Today's Movers -->
  {topMovers.length > 0 && (
    <section class="mb-10">
      <h2 class="text-lg font-bold mb-4 text-gray-800">{t('movers_title')}</h2>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {topMovers.map(m => (
          <a href={`/${lang}/rankings/${m.slug}`}
             class="bg-white rounded-xl border border-gray-200 p-4 hover:shadow-sm hover:border-indigo-200 transition-all flex items-center gap-3">
            <div class={`w-10 h-10 rounded-lg flex items-center justify-center font-bold text-sm flex-shrink-0 ${m.delta > 0 ? 'bg-green-50 text-green-600' : 'bg-red-50 text-red-500'}`}>
              {m.delta > 0 ? `▲${m.delta}` : `▼${Math.abs(m.delta)}`}
            </div>
            <div class="min-w-0">
              <p class="font-semibold text-sm truncate">{m.name}</p>
              <p class="text-xs text-gray-400 truncate">#{m.prev} → #{m.curr} · {m.rankingTitle}</p>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Category Filter -->
  {categories.length > 1 && (
    <div class="flex flex-wrap gap-2 mb-6">
      <button class="px-3 py-1.5 bg-indigo-600 text-white rounded-full text-sm font-medium" data-filter="all">
        {t('all_categories')}
      </button>
      {categories.map(cat => (
        <button class="px-3 py-1.5 bg-gray-100 text-gray-600 rounded-full text-sm font-medium hover:bg-indigo-50 hover:text-indigo-600 transition" data-filter={cat}>{cat}</button>
      ))}
    </div>
  )}

  <!-- Rankings Grid -->
  <section class="mb-12">
    <div class="grid gap-5 md:grid-cols-2" id="rankings-grid">
      {rankings.map((r: any) => {
        const latest = r.history?.at(-1);
        const previous = r.history?.at(-2);
        const i18nData = getI18n(r.i18n, lang);
        const title = i18nData?.title ?? r.slug;
        const top3 = (latest?.rankings ?? [])
          .sort((a: any, b: any) => a.rank - b.rank)
          .slice(0, 3)
          .map((item: any) => {
            const c = r.competitors.find((c: any) => c.id === item.id);
            const prevItem = previous?.rankings?.find((p: any) => p.id === item.id);
            return { ...item, name: c?.name ?? item.id, delta: prevItem ? prevItem.rank - item.rank : 0 };
          });
        return (
          <a href={`/${lang}/rankings/${r.slug}`} data-category={r.category}
             class="bg-white rounded-xl border border-gray-200 p-6 hover:shadow-md hover:border-indigo-300 transition-all block">
            <div class="flex items-center justify-between mb-1">
              <span class="text-xs font-semibold text-indigo-500 uppercase tracking-wide">{r.category}</span>
              {latest?.date && <span class="text-xs text-gray-400">{latest.date}</span>}
            </div>
            <h3 class="text-lg font-bold mb-3">{title}</h3>
            <div class="space-y-1.5 mb-3">
              {top3.map((item: any) => (
                <div class="flex items-center gap-2 text-sm">
                  <span class={`w-5 h-5 rounded flex items-center justify-center text-xs font-bold flex-shrink-0 ${item.rank === 1 ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-500'}`}>
                    {item.rank}
                  </span>
                  <span class="text-gray-700 truncate">{item.name}</span>
                  {item.delta !== 0 && (
                    <span class={`text-xs ml-auto flex-shrink-0 ${item.delta > 0 ? 'text-green-500' : 'text-red-400'}`}>
                      {item.delta > 0 ? `▲${item.delta}` : `▼${Math.abs(item.delta)}`}
                    </span>
                  )}
                </div>
              ))}
            </div>
            <div class="text-xs text-gray-400">{(latest?.rankings ?? []).length} {t('entries_updated')}</div>
          </a>
        );
      })}
    </div>
  </section>
</Layout>

<script>
  const buttons = document.querySelectorAll('[data-filter]');
  const cards = document.querySelectorAll('#rankings-grid [data-category]');
  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter');
      buttons.forEach(b => {
        (b as HTMLElement).className = b === btn
          ? 'px-3 py-1.5 bg-indigo-600 text-white rounded-full text-sm font-medium'
          : 'px-3 py-1.5 bg-gray-100 text-gray-600 rounded-full text-sm font-medium hover:bg-indigo-50 hover:text-indigo-600 transition';
      });
      cards.forEach((card: any) => {
        card.style.display = filter === 'all' || card.getAttribute('data-category') === filter ? '' : 'none';
      });
    });
  });
</script>
