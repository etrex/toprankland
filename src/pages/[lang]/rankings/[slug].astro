---
import Layout from '../../../layouts/Layout.astro';
import { readdir, readFile } from 'fs/promises';
import { join } from 'path';
import { supportedLangs, useTranslations, getI18n, type Lang } from '../../../i18n/translations';

export async function getStaticPaths() {
  const dir = join(process.cwd(), 'src/content/rankings');
  const files = await readdir(dir).catch(() => []);
  const rankings = await Promise.all(
    files.filter(f => f.endsWith('.json'))
      .map(async f => JSON.parse(await readFile(join(dir, f), 'utf-8')))
  );
  return rankings.flatMap(ranking =>
    supportedLangs.map(lang => ({
      params: { lang, slug: ranking.slug },
      props: { ranking, lang },
    }))
  );
}

const { ranking, lang } = Astro.props as { ranking: any; lang: Lang };
const t = useTranslations(lang);

const history = ranking.history ?? [];
const latest = history[history.length - 1];
const previous = history[history.length - 2];

const competitorMap = Object.fromEntries(ranking.competitors.map((c: any) => [c.id, c]));

const currentRankings = (latest?.rankings ?? [])
  .map((r: any) => {
    const prevEntry = previous?.rankings?.find((p: any) => p.id === r.id);
    const delta = prevEntry ? prevEntry.rank - r.rank : 0;
    const competitor = competitorMap[r.id];
    const compI18n = getI18n(competitor?.i18n, lang);
    return { ...r, competitor, compDesc: compI18n?.description || competitor?.description || '', delta };
  })
  .sort((a: any, b: any) => a.rank - b.rank);

// Chart: top 10 rank trend (up to last 365 days)
const chartHistory = history.slice(-365);
const top10Ids = currentRankings.slice(0, 10).map((r: any) => r.id);
const chartLabels = chartHistory.map((h: any) => h.date);
const palette = ['#6366f1','#f59e0b','#10b981','#ef4444','#3b82f6','#8b5cf6','#ec4899','#14b8a6','#f97316','#84cc16'];
const chartDatasets = top10Ids.map((id: string, i: number) => ({
  label: competitorMap[id]?.name ?? id,
  data: chartHistory.map((h: any) => h.rankings.find((r: any) => r.id === id)?.rank ?? null),
  borderColor: palette[i % palette.length],
  backgroundColor: palette[i % palette.length] + '22',
  tension: 0.3,
  fill: false,
  pointRadius: chartHistory.length <= 30 ? 3 : 0,
  pointHoverRadius: 5,
}));
const chartJson = JSON.stringify({ labels: chartLabels, datasets: chartDatasets });
const showChart = chartHistory.length > 1;

const scoreFactorLabels = Object.entries(ranking.scoreFactors ?? {});
const updatedAt = latest?.date ?? '—';

// i18n content for current page
const rankingI18n = getI18n(ranking.i18n, lang);
const rankingTitle = rankingI18n?.title ?? ranking.slug;
const rankingDesc = rankingI18n?.description ?? '';

// Latest commentary/highlights
const latestI18n = getI18n(latest?.i18n, lang);
const commentary = latestI18n?.commentary ?? '';
const highlights = latestI18n?.highlights ?? [];

const currentPath = `/rankings/${ranking.slug}`;
---

<Layout title={rankingTitle} description={rankingDesc} lang={lang} currentPath={currentPath}>
  <div class="mb-6">
    <a href={`/${lang}/`} class="text-sm text-indigo-500 hover:underline">{t('back_all')}</a>
  </div>

  <!-- Header -->
  <div class="mb-8">
    <span class="inline-block text-xs font-semibold text-indigo-500 uppercase tracking-wide bg-indigo-50 px-2 py-1 rounded mb-2">{ranking.category}</span>
    <h1 class="text-3xl font-bold mb-2">{rankingTitle}</h1>
    <p class="text-gray-500 mb-1">{rankingDesc}</p>
    <p class="text-xs text-gray-400">{t('last_updated')}: {updatedAt} · {currentRankings.length} {t('entries_tracked')}</p>
  </div>

  <!-- Rank Trend Chart -->
  {showChart && (
    <section class="bg-white rounded-xl border border-gray-200 p-6 mb-8">
      <h2 class="text-lg font-bold mb-4 text-gray-800">{t('rank_trend')}</h2>
      <div class="relative" style="height: 280px;">
        <canvas id="trendChart"></canvas>
      </div>
      <p class="text-xs text-gray-400 mt-3">{t('chart_note_pre')} {chartHistory.length} {t('chart_note_post')}</p>
    </section>
  )}

  <!-- Current Rankings -->
  <section class="mb-8">
    <h2 class="text-xl font-bold mb-4 text-gray-800">{t('current_rankings')}</h2>
    <div class="space-y-3">
      {currentRankings.map((item: any) => (
        <div class="bg-white rounded-xl border border-gray-200 p-5 hover:shadow-sm hover:border-indigo-200 transition-all">
          <div class="flex items-start gap-4">
            <!-- Rank badge -->
            <div class={`flex-shrink-0 w-12 h-12 rounded-xl flex flex-col items-center justify-center font-bold ${item.rank <= 3 ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-600'}`}>
              <span class="text-base leading-none">#{item.rank}</span>
              {item.delta !== 0 && (
                <span class={`text-xs leading-none mt-0.5 ${item.delta > 0 ? 'text-green-300' : 'text-red-300'}`}>
                  {item.delta > 0 ? `▲${item.delta}` : `▼${Math.abs(item.delta)}`}
                </span>
              )}
            </div>

            <div class="flex-1 min-w-0">
              <div class="flex items-center justify-between gap-2 mb-1 flex-wrap">
                <div>
                  <a href={item.competitor?.url ?? '#'} target="_blank" rel="noopener"
                     class="text-lg font-bold hover:text-indigo-600 transition-colors">
                    {item.competitor?.name ?? item.id}
                  </a>
                  {item.competitor?.brand && (
                    <span class="ml-2 text-xs text-gray-400">{item.competitor.brand}</span>
                  )}
                </div>
                <div class="flex items-center gap-3">
                  {item.competitor?.priceRange && (
                    <span class="text-sm text-gray-400">{item.competitor.priceRange}</span>
                  )}
                  <span class="text-lg font-bold text-indigo-600">{item.score.toFixed(1)}<span class="text-xs text-gray-400 font-normal">/10</span></span>
                </div>
              </div>

              {item.compDesc && (
                <p class="text-sm text-gray-500 mb-3">{item.compDesc}</p>
              )}

              <!-- Score factor bars -->
              {scoreFactorLabels.length > 0 && item.scores && (
                <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-x-4 gap-y-2">
                  {scoreFactorLabels.map(([key, label]: [string, any]) => (
                    <div>
                      <div class="flex justify-between text-xs text-gray-400 mb-0.5">
                        <span class="truncate pr-1">{label}</span>
                        <span class="font-medium text-gray-600 flex-shrink-0">{item.scores[key]?.toFixed(1) ?? '—'}</span>
                      </div>
                      <div class="h-1.5 bg-gray-100 rounded-full overflow-hidden">
                        <div class="h-full bg-indigo-400 rounded-full"
                             style={`width: ${((item.scores[key] ?? 0) / 10) * 100}%`}></div>
                      </div>
                    </div>
                  ))}
                </div>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Daily Commentary -->
  {commentary && (
    <section class="bg-indigo-50 rounded-xl border border-indigo-100 p-6 mb-6">
      <h2 class="text-lg font-bold mb-3 text-indigo-800">{t('todays_analysis')} · {updatedAt}</h2>
      <p class="text-gray-700 leading-relaxed mb-4">{commentary}</p>
      {highlights.length > 0 && (
        <div>
          <p class="text-sm font-semibold text-indigo-700 mb-2">{t('key_highlights')}</p>
          <ul class="space-y-1.5">
            {highlights.map((h: string) => (
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <span class="text-indigo-400 mt-0.5 flex-shrink-0">→</span>
                <span>{h}</span>
              </li>
            ))}
          </ul>
        </div>
      )}
    </section>
  )}

  <!-- References -->
  {latest?.references?.length > 0 && (
    <section class="mb-8">
      <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-wide mb-3">{t('references')}</h3>
      <div class="flex flex-wrap gap-2">
        {latest.references.map((ref: any) => (
          <a href={ref.url} target="_blank" rel="noopener"
             class="inline-flex items-center gap-1.5 text-xs bg-white border border-gray-200 rounded-lg px-3 py-1.5 text-gray-600 hover:border-indigo-300 hover:text-indigo-600 transition-all">
            <span class="font-medium">{ref.source}</span>
            <span class="text-gray-400">↗</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- History Log -->
  {history.length > 1 && (
    <section class="mb-8">
      <h2 class="text-lg font-bold mb-6 text-gray-800">{t('update_history')}</h2>
      <div class="space-y-8">
        {[...history].reverse().slice(1, 11).map((entry: any) => {
          const entryI18n = getI18n(entry.i18n, lang);
          const entryCommentary = entryI18n?.commentary ?? '';
          const entryHighlights = entryI18n?.highlights ?? [];
          const paragraphs = entryCommentary.split(/\n\n+/).filter(Boolean);
          return (
            <article class="bg-white rounded-xl border border-gray-200 p-6">
              <h3 class="text-sm font-bold text-indigo-600 mb-4 pb-3 border-b border-gray-100">{entry.date}</h3>
              {paragraphs.length > 0 && (
                <div class="space-y-3 mb-5">
                  {paragraphs.map((para: string) => (
                    <p class="text-sm text-gray-700 leading-relaxed">{para}</p>
                  ))}
                </div>
              )}
              {entryHighlights.length > 0 && (
                <div class="bg-gray-50 rounded-lg p-4">
                  <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">{t('key_highlights')}</p>
                  <ul class="space-y-1.5">
                    {entryHighlights.map((h: string) => (
                      <li class="flex items-start gap-2 text-sm text-gray-600">
                        <span class="text-indigo-400 mt-0.5 flex-shrink-0">→</span>
                        <span>{h}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
              {entry.references?.length > 0 && (
                <div class="flex flex-wrap gap-2 mt-4 pt-3 border-t border-gray-100">
                  {entry.references.map((ref: any) => (
                    <a href={ref.url} target="_blank" rel="noopener"
                       class="inline-flex items-center gap-1 text-xs text-gray-400 hover:text-indigo-600 transition-colors">
                      <span>{ref.source}</span>
                      <span>↗</span>
                    </a>
                  ))}
                </div>
              )}
            </article>
          );
        })}
      </div>
    </section>
  )}
</Layout>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js" is:inline></script>
{showChart && (
  <script define:vars={{ chartJson }}>
    const data = JSON.parse(chartJson);
    const ctx = document.getElementById('trendChart');
    if (ctx) {
      new Chart(ctx, {
        type: 'line',
        data,
        options: {
          responsive: true,
          maintainAspectRatio: false,
          scales: {
            y: {
              reverse: true,
              min: 1,
              ticks: { stepSize: 1, font: { size: 11 }, callback: (v) => `#${v}` },
              grid: { color: '#f3f4f6' }
            },
            x: {
              ticks: { maxTicksLimit: 12, font: { size: 11 } },
              grid: { display: false }
            }
          },
          plugins: {
            legend: { position: 'bottom', labels: { font: { size: 11 }, boxWidth: 12, padding: 12 } },
            tooltip: { callbacks: { label: (c) => ` ${c.dataset.label}: #${c.raw}` } }
          },
          interaction: { mode: 'index', intersect: false }
        }
      });
    }
  </script>
)}
